{
  "name": "@alignmenteconomy/sdk",
  "version": "0.3.0",
  "description": "TypeScript SDK for the Alignment Economy. Typed wrappers around the ae-node HTTP API + crypto primitives for signing transactions and managing wallets.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@noble/post-quantum": "^0.6.0",
    "@scure/bip39": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
