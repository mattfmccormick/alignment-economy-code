# Copy this file to .env and fill in real values. Never commit .env.
#
# Generate the cryptographic secrets with:
#   openssl rand -hex 32

# ── Required cryptographic secrets ─────────────────────────────────────

# Server's long-term x25519 private key. The corresponding public key
# is what the wallet uses to encrypt recovery_blobs. Server decrypts
# recovery_blobs with this during a verified recovery flow.
# CRITICAL: in prod, store this in a secret manager (Fly.io secrets,
# Render env vars, AWS KMS) and rotate after any suspected compromise.
AE_PLATFORM_RECOVERY_PRIVATE_KEY=

# HMAC key for session tokens. Compromise of this lets an attacker
# mint valid session tokens for any user, which lets them sign in
# without the password. Same handling as the recovery key.
AE_PLATFORM_SESSION_SECRET=

# ── Hosting / domain ───────────────────────────────────────────────────

# Used by the Caddy reverse-proxy. Point your DNS A record at the VPS
# IP, set this to the hostname, and Caddy auto-fetches a Let's Encrypt
# cert. For local prod-like testing without TLS, set to `:80`.
AE_PLATFORM_DOMAIN=platform.alignmenteconomy.org

# ── Optional: email mode ──────────────────────────────────────────────

# `dev` logs recovery + verification email bodies to stdout. Fine for
# beta with a tester group; real users need `smtp`.
AE_PLATFORM_EMAIL_MODE=dev

# Fill these only when AE_PLATFORM_EMAIL_MODE=smtp.
# Resend's smtp.resend.com works out of the box once you've verified
# the sender domain. SendGrid, Amazon SES, Postmark all work too.
# AE_PLATFORM_SMTP_HOST=smtp.resend.com
# AE_PLATFORM_SMTP_PORT=465
# AE_PLATFORM_SMTP_USER=resend
# AE_PLATFORM_SMTP_PASSWORD=re_AbCd...
# AE_PLATFORM_SMTP_FROM=noreply@alignmenteconomy.org
